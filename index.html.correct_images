<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>3D Tarot Reading</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        body { margin: 0; background: #0d0e1a; font-family: Arial, sans-serif; color: #fff; }
        .card-item {
            transition: transform 0.2s, background 0.2s;
        }
        .card-item:hover {
            transform: scale(1.05);
        }
        .card-item.selected {
            background: #4CAF50 !important;
            border-color: #66BB6A !important;
        }
    </style>
</head>
<body>
    <div id="root"></div>
    
    <script type="text/babel">
        const { useState, useEffect } = React;
        
        function App() {
            const [allCards, setAllCards] = useState([]);
            const [availableCards, setAvailableCards] = useState([]);
            const [selectedCards, setSelectedCards] = useState([]);
            const [view, setView] = useState('select');
            
            useEffect(() => {
                fetch('./assets/tarot-deck.local.json')
                    .then(r => r.json())
                    .then(data => {
                        console.log('✅ 加载了', data.cards.length, '张牌');
                        setAllCards(data.cards);
                        
                        // 只显示有图片的牌
                        const withImages = data.cards.filter(card => {
                            const cid = card.card_id;
                            // 根据实际存在的图片文件过滤
                            const hasImage = checkImageExists(cid);
                            return hasImage;
                        });
                        
                        console.log('✅ 有图片的牌：', withImages.length, '张');
                        setAvailableCards(withImages);
                    })
                    .catch(e => console.error('❌ 加载失败:', e));
            }, []);
            
            // 检查图片是否存在（基于之前的分析）
            const checkImageExists = (cardId) => {
                // 已知存在的图片文件列表
                const existingImages = [
                    'ar00', 'ar01', 'ar02', 'ar03', 'ar04', 'ar05', 'ar06', 'ar07',
                    'ar09', 'ar11', 'ar12', 'ar13', 'ar14', 'ar15', 'ar16', 'ar17',
                    'ar18', 'ar19', 'ar21',
                    'wa02', 'wa03', 'wa04', 'wa06', 'wa08', 'wa10',
                    'cu02', 'cu04', 'cu07', 'cu09', 'cu10',
                    'sw02', 'sw04', 'sw06', 'sw08', 'sw09', 'sw10',
                    'pe02', 'pe03', 'pe05', 'pe06', 'pe07', 'pe09'
                ];
                return existingImages.includes(cardId);
            };
            
            const selectCard = (card) => {
                if (selectedCards.length < 3 && !selectedCards.find(c => c.card_id === card.card_id)) {
                    const newSelected = [...selectedCards, card];
                    setSelectedCards(newSelected);
                    console.log('已选择', newSelected.length, '张牌');
                    
                    if (newSelected.length === 3) {
                        setTimeout(() => {
                            console.log('切换到解读视图');
                            setView('result');
                        }, 500);
                    }
                }
            };
            
            const reset = () => {
                setSelectedCards([]);
                setView('select');
            };
            
            if (view === 'select') {
                return (
                    <div style={{padding: '40px', minHeight: '100vh'}}>
                        <h1 style={{textAlign: 'center', fontSize: '2.5rem', marginBottom: '10px', color: '#F7E7CE'}}>
                            塔罗解读
                        </h1>
                        <p style={{textAlign: 'center', marginBottom: '30px', color: '#9d85c4', fontSize: '14px'}}>
                            已选择 {selectedCards.length}/3 张牌 | 可用 {availableCards.length} 张
                        </p>
                        
                        <div style={{
                            display: 'grid',
                            gridTemplateColumns: 'repeat(auto-fill, minmax(140px, 1fr))',
                            gap: '15px',
                            maxWidth: '1400px',
                            margin: '0 auto'
                        }}>
                            {availableCards.map((card, i) => {
                                const isSelected = selectedCards.find(c => c.card_id === card.card_id);
                                const imagePath = `./assets/cards/${card.card_id}.jpg`;
                                
                                return (
                                    <div
                                        key={i}
                                        onClick={() => !isSelected && selectCard(card)}
                                        className={`card-item ${isSelected ? 'selected' : ''}`}
                                        style={{
                                            padding: '10px',
                                            background: isSelected ? '#4CAF50' : '#2d2d3d',
                                            color: '#fff',
                                            border: isSelected ? '2px solid #66BB6A' : '1px solid #444',
                                            borderRadius: '12px',
                                            cursor: isSelected ? 'default' : 'pointer',
                                            opacity: isSelected ? 0.8 : 1,
                                            display: 'flex',
                                            flexDirection: 'column',
                                            alignItems: 'center'
                                        }}
                                    >
                                        <img 
                                            src={imagePath}
                                            alt={card.name}
                                            style={{
                                                width: '100%',
                                                height: '180px',
                                                objectFit: 'cover',
                                                borderRadius: '8px',
                                                marginBottom: '8px'
                                            }}
                                            onError={(e) => {
                                                e.target.style.display = 'none';
                                            }}
                                        />
                                        <div style={{fontSize: '12px', textAlign: 'center', lineHeight: '1.4'}}>
                                            {card.name || card.card_id}
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                );
            }
            
            // 结果视图
            return (
                <div style={{padding: '40px', minHeight: '100vh', maxWidth: '1000px', margin: '0 auto'}}>
                    <h1 style={{textAlign: 'center', fontSize: '2.5rem', marginBottom: '40px', color: '#F7E7CE'}}>
                        你的塔罗解读
                    </h1>
                    
                    <div style={{
                        display: 'grid',
                        gridTemplateColumns: 'repeat(3, 1fr)',
                        gap: '20px',
                        marginBottom: '40px'
                    }}>
                        {selectedCards.map((card, i) => (
                            <div key={i} style={{
                                background: '#2d2d3d',
                                padding: '20px',
                                borderRadius: '12px',
                                border: '1px solid #444',
                                textAlign: 'center'
                            }}>
                                <div style={{fontSize: '12px', color: '#9d85c4', marginBottom: '10px'}}>
                                    {i === 0 ? '过去' : i === 1 ? '现在' : '未来'}
                                </div>
                                <img 
                                    src={`./assets/cards/${card.card_id}.jpg`}
                                    alt={card.name}
                                    style={{
                                        width: '100%',
                                        maxWidth: '200px',
                                        height: 'auto',
                                        borderRadius: '8px',
                                        marginBottom: '10px'
                                    }}
                                />
                                <h3 style={{fontSize: '16px', marginBottom: '10px', color: '#F7E7CE'}}>
                                    {card.name || card.card_id}
                                </h3>
                            </div>
                        ))}
                    </div>
                    
                    {selectedCards.map((card, i) => (
                        <div key={i} style={{
                            background: '#2d2d3d',
                            padding: '30px',
                            borderRadius: '12px',
                            marginBottom: '20px',
                            border: '1px solid #444'
                        }}>
                            <h2 style={{fontSize: '20px', marginBottom: '15px', color: '#F7E7CE'}}>
                                {i === 0 ? '过去：' : i === 1 ? '现在：' : '未来：'} {card.name}
                            </h2>
                            
                            <div style={{marginBottom: '15px'}}>
                                <h3 style={{fontSize: '16px', color: '#9d85c4', marginBottom: '10px'}}>
                                    正位解读：
                                </h3>
                                <p style={{lineHeight: '1.8', color: '#d1d5db'}}>
                                    {card.up || '暂无解读'}
                                </p>
                            </div>
                            
                            <div>
                                <h3 style={{fontSize: '16px', color: '#9d85c4', marginBottom: '10px'}}>
                                    逆位解读：
                                </h3>
                                <p style={{lineHeight: '1.8', color: '#d1d5db'}}>
                                    {card.down || '暂无解读'}
                                </p>
                            </div>
                        </div>
                    ))}
                    
                    <button
                        onClick={reset}
                        style={{
                            display: 'block',
                            margin: '40px auto 0',
                            padding: '15px 40px',
                            background: '#4CAF50',
                            color: '#fff',
                            border: 'none',
                            borderRadius: '8px',
                            fontSize: '16px',
                            cursor: 'pointer'
                        }}
                    >
                        重新选择
                    </button>
                </div>
            );
        }
        
        ReactDOM.render(<App />, document.getElementById('root'));
    </script>
</body>
</html>
